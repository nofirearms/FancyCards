<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:FancyCards.Converters"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <SolidColorBrush x:Key="ThemeForeground" Color="White" />

    <SolidColorBrush x:Key="PrimaryForeground" Color="{Binding Color, Source={StaticResource MaterialDesign.Brush.Primary}}" />

    <SolidColorBrush x:Key="SecondaryForeground" Color="{Binding Color, Source={StaticResource MaterialDesign.Brush.Secondary}}" />

    <SolidColorBrush x:Key="StateIconBrush" Color="{Binding Color, Source={StaticResource MaterialDesign.Brush.Primary}}" />

    <SolidColorBrush x:Key="SearchIconBrush" Color="White" />

</ResourceDictionary>