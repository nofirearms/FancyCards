<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">


    <SolidColorBrush x:Key="ThemeForeground" Color="Black" />

    <SolidColorBrush x:Key="PrimaryForeground" Color="Black" />

    <SolidColorBrush x:Key="SecondaryForeground" Color="{Binding Color, Source={StaticResource MaterialDesign.Brush.Secondary}}" />

    <SolidColorBrush x:Key="StateIconBrush" Color="{Binding Color, Source={StaticResource MaterialDesign.Brush.Primary}}" />

    <SolidColorBrush x:Key="SearchIconBrush" Color="{Binding Color, Source={StaticResource MaterialDesign.Brush.Primary}}" />

</ResourceDictionary>