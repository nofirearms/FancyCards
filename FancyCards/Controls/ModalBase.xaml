<UserControl
    x:Class="FancyCards.Controls.ModalBase"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:FancyCards.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <Grid.Background>
            <SolidColorBrush Opacity="0.5" Color="Black" />
        </Grid.Background>

        <Border
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{DynamicResource MaterialDesign.Brush.Secondary.Light}"
            CornerRadius="3"
            UseLayoutRounding="True">
            <ContentPresenter
                Grid.Row="1"
                Margin="-5"
                Content="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=Content}" />
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" />
            </Border.Effect>
        </Border>
    </Grid>
</UserControl>
