<UserControl
    x:Class="FancyCards.Controls.AudioGraph"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:FancyCards.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid x:Name="AudioGraphGrid">
        <Grid
            x:Name="AudioGraphBorder"
            HorizontalAlignment="Left"
            IsHitTestVisible="True">
            <Polyline
                x:Name="AudioGraphPolyline"
                Height="100"
                HorizontalAlignment="Left"
                Fill="Red"
                Stretch="None">
                <!--<interaction:Interaction.Triggers>
                    <interaction:DataTrigger Binding="{Binding ElementName=AudioGraph, Path=Points.Count}" Value="0">
                        <interaction:ChangePropertyAction
                                        PropertyName="Visibility"
                                        TargetObject="{Binding ElementName=AudioGraphBorder}"
                                        Value="Hidden" />
                    </interaction:DataTrigger>
                    <interaction:DataTrigger
                                    Binding="{Binding ElementName=AudioGraph, Path=Points.Count}"
                                    Comparison="GreaterThan"
                                    Value="0">
                        <interaction:ChangePropertyAction
                                        PropertyName="Visibility"
                                        TargetObject="{Binding ElementName=AudioGraphBorder}"
                                        Value="Visible" />
                    </interaction:DataTrigger>
                </interaction:Interaction.Triggers>-->
                <Polyline.LayoutTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Polyline.LayoutTransform>
            </Polyline>
            <Border BorderBrush="BlueViolet" BorderThickness="1" />
            <Canvas
                x:Name="ManipulationCanvas"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="Transparent"
                IsHitTestVisible="False">
                <Line
                    x:Name="CurrentPositionLine"
                    Stroke="Black"
                    StrokeThickness="1"
                    Visibility="Collapsed"
                    X1="0"
                    X2="0"
                    Y1="0"
                    Y2="100" />
                <Line
                    x:Name="PlaybackStartPositionLine"
                    HorizontalAlignment="Center"
                    Stroke="Red"
                    StrokeThickness="2"
                    Visibility="Collapsed"
                    X1="0"
                    X2="0"
                    Y1="0.5"
                    Y2="99.5" />
            </Canvas>

        </Grid>
    </Grid>
</UserControl>
