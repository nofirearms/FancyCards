<UserControl
    x:Class="FancyCards.Controls.ContextBase"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:FancyCards.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="100"
    d:DesignWidth="100"
    mc:Ignorable="d">
    <Grid>
        <Border MouseDown="BackgroundMouseDown">
            <Border.Background>
                <SolidColorBrush Opacity="0.5" Color="Black" />
            </Border.Background>
        </Border>

        <Canvas x:Name="MainCanvas">
            <Grid
                x:Name="ImageGrid"
                Background="{DynamicResource MaterialDesign.Brush.Primary.Light}"
                MouseDown="BackgroundMouseDown">
                <Image x:Name="ParentImage" />
            </Grid>

            <Border
                x:Name="ContentBorder"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Panel.ZIndex="10"
                Background="{DynamicResource MaterialDesign.Brush.Secondary.Light}"
                CornerRadius="3"
                UseLayoutRounding="True">
                <ContentPresenter
                    x:Name="ContextContent"
                    Margin="5"
                    Content="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=Content}"
                    DataContextChanged="ContextContent_DataContextChanged"
                    LayoutUpdated="ContextContent_LayoutUpdated" />
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" />
                </Border.Effect>
            </Border>
        </Canvas>

    </Grid>
</UserControl>
