<UserControl
    x:Class="FancyCards.Controls.AnswerTextBoxControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:FancyCards.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="root"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Border
        x:Name="MainBorder"
        GotFocus="OnMainBorderGotFocus"
        LostFocus="OnMainBorderLostFocus"
        MouseDown="OnMainBorderMouseDown"
        Style="{StaticResource CustomBorderStyle}">
        <Grid Margin="10" Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>

            <TextBlock
                x:Name="PrefixTextBlock"
                Grid.Row="0"
                Margin="0,-5,0,0"
                FontSize="12"
                Foreground="{StaticResource InactiveForeground}"
                Text="{Binding ElementName=root, Path=Prefix}"
                TextAlignment="Left"
                TextWrapping="Wrap">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="Text" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <TextBox
                x:Name="AnswerTextbox"
                Grid.Row="1"
                Text="{Binding ElementName=root, Path=Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TextBox">
                                    <Grid>
                                        <!--  Border - визуальная оболочка  -->
                                        <Border
                                            x:Name="border"
                                            Margin="-2,0"
                                            SnapsToDevicePixels="True">

                                            <!--  ScrollViewer для прокрутки текста  -->
                                            <ScrollViewer
                                                x:Name="PART_ContentHost"
                                                VerticalAlignment="Center"
                                                HorizontalScrollBarVisibility="Auto"
                                                VerticalScrollBarVisibility="Auto" />
                                        </Border>

                                    </Grid>

                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TextBox.Style>
            </TextBox>
            <TextBlock
                x:Name="SuffixTextBlock"
                Grid.Row="2"
                Margin="0,0,0,-5"
                HorizontalAlignment="Right"
                FontSize="12"
                Foreground="{StaticResource InactiveForeground}"
                Text="{Binding ElementName=root, Path=Suffix}"
                TextAlignment="Left"
                TextWrapping="Wrap">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="Text" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>
    </Border>

</UserControl>
