<Window
    x:Class="FancyCards.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:FancyCards.Controls"
    xmlns:converters="clr-namespace:FancyCards.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:interaction="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:FancyCards.Views"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:FancyCards.ViewModels"
    x:Name="root"
    Title="{Binding Title}"
    Width="500"
    Height="700"
    d:DataContext="{d:DesignInstance vm:MainWindowViewModel}"
    Style="{StaticResource MaterialDesignWindow}"
    mc:Ignorable="d">
    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>
    <Grid>
        <!--  Модальные окна  -->
        <ItemsControl Panel.ZIndex="10" ItemsSource="{Binding ActiveModals}">
            <ItemsControl.Resources>
                <DataTemplate DataType="{x:Type vm:CardDetailViewModel}">
                    <controls:ModalBase
                        Margin="0"
                        ContentLoaded="{Binding RelativeSource={RelativeSource AncestorType=ItemsControl}, Path=DataContext.ModalLoadedCommand}"
                        ContentLoading="{Binding RelativeSource={RelativeSource AncestorType=ItemsControl}, Path=DataContext.ModalLoadingCommand}">
                        <local:CardDetailView />
                    </controls:ModalBase>

                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:MessageBoxViewModel}">
                    <controls:ModalBase ModalBackground="PaleGreen">
                        <local:MessageBoxView  />
                    </controls:ModalBase>
                </DataTemplate>

                <DataTemplate DataType="{x:Type vm:TrainingViewModel}">
                    <controls:ModalBase ContentLoaded="{Binding RelativeSource={RelativeSource AncestorType=ItemsControl}, Path=DataContext.ModalLoadedCommand}">
                        <local:TrainingView />
                    </controls:ModalBase>
                </DataTemplate>

                <DataTemplate DataType="{x:Type vm:TrainingStartViewModel}">
                    <controls:ModalBase>
                        <local:TrainingStartView />
                    </controls:ModalBase>
                </DataTemplate>

            </ItemsControl.Resources>
            <!--<ItemsControl.ItemTemplate>
                <DataTemplate>
                    <controls:ModalBase
                        Content="{Binding}"
                        ContentLoaded="{Binding RelativeSource={RelativeSource AncestorType=ItemsControl}, Path=DataContext.ModalLoadedCommand}"
                        ContentLoading="{Binding RelativeSource={RelativeSource AncestorType=ItemsControl}, Path=DataContext.ModalLoadingCommand}" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>-->

            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>

        <!--  Контекстное меню  -->
        <controls:ContextBase
            Panel.ZIndex="11"
            d:Visibility="Collapsed"
            Content="{Binding ContextMenu}"
            Visibility="{Binding ContextMenuOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <controls:ContextBase.Resources>
                <DataTemplate DataType="{x:Type vm:CardContextViewModel}">
                    <local:CardContextView />
                </DataTemplate>
            </controls:ContextBase.Resources>
        </controls:ContextBase>

        <DockPanel>
            <StackPanel
                HorizontalAlignment="Center"
                DockPanel.Dock="Bottom"
                Orientation="Horizontal">
                <Button Command="{Binding StartTrainingCommand}" Content="{materialDesign:PackIcon Kind=PlayBox}" />
                <Button Command="{Binding CreateCardCommand}" Content="{materialDesign:PackIcon Kind=Add}" />
                <Button Command="{Binding OpenStatsModal}" Content="{materialDesign:PackIcon Kind=ChartBar}" />
                <Button Command="{Binding OpenSettingsModal}" Content="{materialDesign:PackIcon Kind=Settings}" />
                <Button Command="{Binding OpenReplaceModal}" Content="{materialDesign:PackIcon Kind=Cached}" />
            </StackPanel>

            <local:CardListView DataContext="{Binding CardListViewModel}" />
        </DockPanel>


        <Grid d:Visibility="Collapsed" Visibility="{Binding Loading, Converter={StaticResource BoolToVisibilityConverter}}">
            <!--<ProgressBar IsIndeterminate="True" Style="{StaticResource MaterialDesignCircularProgressBar}" />
            <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="White"
                Text="LOADING..." />-->
            <Grid.Background>
                <SolidColorBrush Opacity="0.5" Color="Black" />
            </Grid.Background>
        </Grid>

    </Grid>

</Window>
