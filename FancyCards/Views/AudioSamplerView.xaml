<UserControl
    x:Class="FancyCards.Views.AudioSamplerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:FancyCards.Controls"
    xmlns:converters="clr-namespace:FancyCards.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:FancyCards.Views"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:model="clr-namespace:FancyCards.Models"
    xmlns:vm="clr-namespace:FancyCards.ViewModels"
    d:DataContext="{d:DesignInstance vm:AudioSamplerViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>
    <Grid>

        <DockPanel>

            <StackPanel
                Margin="0,5"
                DockPanel.Dock="Top"
                Orientation="Horizontal">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon
                        Width="25"
                        Height="25"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource MaterialDesign.Brush.Primary}"
                        Kind="VolumeMedium" />
                    <Slider
                        x:Name="VolumeSlider"
                        Width="100"
                        VerticalAlignment="Center"
                        IsSnapToTickEnabled="True"
                        Maximum="1"
                        Minimum="0"
                        Style="{StaticResource MaterialDesignSlider}"
                        TickFrequency="0.1"
                        Value="{Binding Volume, Mode=TwoWay}" />
                    <TextBlock
                        Margin="5,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="{StaticResource MaterialDesign.Brush.Primary}"
                        Text="{Binding ElementName=VolumeSlider, Path=Value, StringFormat='f1'}" />
                </StackPanel>

                <StackPanel Margin="20,0,0,0" Orientation="Horizontal">
                    <materialDesign:PackIcon
                        Width="25"
                        Height="20"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource MaterialDesign.Brush.Primary}"
                        Kind="RunFast" />
                    <Slider
                        x:Name="TempoSlider"
                        Width="100"
                        VerticalAlignment="Center"
                        IsSnapToTickEnabled="True"
                        Maximum="2"
                        Minimum="0.8"
                        Style="{StaticResource MaterialDesignSlider}"
                        TickFrequency="0.1"
                        Value="{Binding Tempo, Mode=TwoWay}" />
                    <TextBlock
                        Margin="5,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="{StaticResource MaterialDesign.Brush.Primary}"
                        Text="{Binding ElementName=TempoSlider, Path=Value, StringFormat='f1'}" />
                </StackPanel>

            </StackPanel>

            <StackPanel
                HorizontalAlignment="Center"
                DockPanel.Dock="Bottom"
                Orientation="Horizontal">
                <Grid Margin="2,2">
                    <Button Command="{Binding StopRecordingCommand}">
                        <Button.Content>
                            <materialDesign:PackIcon
                                Width="25"
                                Height="25"
                                Kind="StopCircle" />
                        </Button.Content>
                        <Button.Style>
                            <Style BasedOn="{StaticResource TransparentSquareButton}" TargetType="Button">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <!--  Переопределяем только для Recording  -->
                                    <DataTrigger Binding="{Binding AudioSamplerState}" Value="Recording">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Command="{Binding StartRecordingCommand}" Foreground="Red">
                        <Button.Content>
                            <materialDesign:PackIcon
                                Width="25"
                                Height="25"
                                Kind="Record" />
                        </Button.Content>
                        <Button.Style>
                            <Style BasedOn="{StaticResource TransparentSquareButton}" TargetType="Button">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <!--  Переопределяем только для Recording  -->
                                    <DataTrigger Binding="{Binding AudioSamplerState}" Value="Recording">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
                <StackPanel Orientation="Horizontal">
                    <Button
                        Margin="2,2"
                        Command="{Binding StartPlaybackCommand}"
                        CommandParameter="{x:Static model:PlaybackMode.Selected}"
                        Style="{StaticResource TransparentSquareButton}">
                        <Button.Content>
                            <StackPanel>
                                <materialDesign:PackIcon
                                    Width="15"
                                    Height="15"
                                    HorizontalAlignment="Center"
                                    Kind="Play" />
                                <TextBlock FontSize="8" Text="SEL" />
                            </StackPanel>
                        </Button.Content>
                    </Button>
                    <Button
                        Margin="2,2"
                        Command="{Binding StartPlaybackCommand}"
                        CommandParameter="{x:Static model:PlaybackMode.Full}"
                        Style="{StaticResource TransparentSquareButton}">
                        <Button.Content>
                            <StackPanel>
                                <materialDesign:PackIcon
                                    Width="15"
                                    Height="15"
                                    HorizontalAlignment="Center"
                                    Kind="Play" />
                                <TextBlock FontSize="8" Text="FULL" />
                            </StackPanel>

                        </Button.Content>
                    </Button>
                    <Button
                        Margin="2,2"
                        Command="{Binding StartPlaybackCommand}"
                        CommandParameter="{x:Static model:PlaybackMode.SelectedSlow}"
                        Style="{StaticResource TransparentSquareButton}">
                        <Button.Content>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="15"
                                        Height="15"
                                        VerticalAlignment="Center"
                                        Kind="Play" />
                                    <materialDesign:PackIcon
                                        Width="10"
                                        Height="10"
                                        VerticalAlignment="Center"
                                        Kind="FractionOneHalf" />
                                </StackPanel>

                                <TextBlock FontSize="8" Text="SPEED" />
                            </StackPanel>
                        </Button.Content>
                    </Button>
                    <Button
                        Margin="2,2"
                        Command="{Binding StopPlaybackCommand}"
                        Style="{StaticResource TransparentSquareButton}">
                        <Button.Content>
                            <materialDesign:PackIcon
                                Width="25"
                                Height="25"
                                Kind="Stop" />
                        </Button.Content>
                    </Button>
                </StackPanel>
            </StackPanel>

            <Border
                Margin="1"
                Padding="1"
                BorderBrush="black"
                BorderThickness="1"
                CornerRadius="3">

                <Grid>
                    <controls:AudioGraph
                        PlaybackCurrentPosition="{Binding PlaybackCurrentPosition}"
                        Points="{Binding Points}"
                        SamplerState="{Binding AudioSamplerState}"
                        Selection="{Binding Selection, Mode=TwoWay}"
                        StartPlaybackPosition="{Binding PlaybackStartPosition, Mode=TwoWay}" />
                    <TextBlock
                        Margin="6,-15"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        FontSize="11"
                        IsHitTestVisible="False"
                        Text="{Binding AudioDuration, StringFormat='{}{0:m\\:ss\\.fff}'}" />
                </Grid>
            </Border>
        </DockPanel>

    </Grid>
</UserControl>
