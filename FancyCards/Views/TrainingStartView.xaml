<UserControl
    x:Class="FancyCards.Views.TrainingStartView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:FancyCards.Views"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:FancyCards.ViewModels"
    d:DataContext="{d:DesignInstance vm:TrainingStartViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <StackPanel>
        <TextBlock />

        <Button
            Width="40"
            Height="40"
            Padding="0"
            Command="{Binding StartTrainingCommand}"
            Content="{materialDesign:PackIcon Kind=Play}" />

        <Button
            Width="40"
            Height="40"
            Padding="0"
            Command="{Binding CancelTrainingCommand}"
            Content="{materialDesign:PackIcon Kind=Cancel}" />

    </StackPanel>
</UserControl>
