<UserControl
    x:Class="FancyCards.Views.TrainingStartView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:FancyCards.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:FancyCards.Views"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:FancyCards.ViewModels"
    Width="200"
    Height="200"
    d:Background="Wheat"
    d:DataContext="{d:DesignInstance vm:TrainingStartViewModel}"
    mc:Ignorable="d">
    <StackPanel>
        <TextBlock
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontSize="18"
            Text="Start Training" />
        <controls:CustomNumericControl
            Margin="0,0,0,5"
            DefaultValue="10"
            Frequency="1"
            MaxValue="{Binding MaxLearnCardsCount}"
            MinValue="0"
            Value="{Binding LearnCardsCount, Mode=TwoWay}">
            <controls:CustomNumericControl.ContentTemplate>
                <DataTemplate>
                    <Border BorderThickness="1" CornerRadius="3">
                        <TextBlock>
                            <Run Text="Learn cards:" />
                            <Run Foreground="{StaticResource MaterialDesign.Brush.Primary}" Text="{Binding Path=.}" />
                            <Run Text=" | " />
                            <Run FontWeight="Bold" Text="{Binding RelativeSource={RelativeSource AncestorType=StackPanel}, Path=DataContext.MaxLearnCardsCount}" />
                        </TextBlock>
                    </Border>
                </DataTemplate>
            </controls:CustomNumericControl.ContentTemplate>
        </controls:CustomNumericControl>

        <controls:CustomNumericControl
            Margin="0,0,0,5"
            DefaultValue="10"
            Frequency="1"
            MaxValue="{Binding MaxReviewCardsCount}"
            MinValue="0"
            Value="{Binding ReviewCardsCount, Mode=TwoWay}">
            <controls:CustomNumericControl.ContentTemplate>
                <DataTemplate>
                    <Border BorderThickness="1" CornerRadius="3">
                        <TextBlock>
                            <Run Text="Review cards:" />
                            <Run Foreground="{StaticResource MaterialDesign.Brush.Primary}" Text="{Binding Path=.}" />
                            <Run Text=" | " />
                            <Run FontWeight="Bold" Text="{Binding RelativeSource={RelativeSource AncestorType=StackPanel}, Path=DataContext.MaxReviewCardsCount}" />
                        </TextBlock>
                    </Border>
                </DataTemplate>
            </controls:CustomNumericControl.ContentTemplate>
        </controls:CustomNumericControl>

        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
            <Button
                Width="40"
                Height="40"
                Padding="0"
                Command="{Binding StartTrainingCommand}"
                Content="{materialDesign:PackIcon Kind=Play}" />

            <Button
                Width="40"
                Height="40"
                Padding="0"
                Command="{Binding CancelTrainingCommand}"
                Content="{materialDesign:PackIcon Kind=Cancel}" />
        </StackPanel>



    </StackPanel>
</UserControl>
