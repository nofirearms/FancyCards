<UserControl
    x:Class="FancyCards.Views.TrainingStartView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:FancyCards.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:FancyCards.Views"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:FancyCards.ViewModels"
    Width="200"
    Height="100"
    d:Background="Wheat"
    d:DataContext="{d:DesignInstance vm:TrainingStartViewModel}"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <controls:CustomNumericControl
                Margin="0,0,0,0"
                DefaultValue="{Binding DefaultLearnCardsCount}"
                Frequency="1"
                MaxValue="{Binding MaxLearnCardsCount}"
                MinValue="0"
                MouseOverBackgroundVisibility="Visible"
                MouseOverOverlay="{StaticResource MaterialDesign.Brush.Primary.Foreground}"
                Value="{Binding LearnCardsCount, Mode=TwoWay}">
                <controls:CustomNumericControl.ContentTemplate>
                    <DataTemplate>
                        <Border
                            Padding="3"
                            BorderThickness="1"
                            CornerRadius="3">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Width="85">
                                    <Run Text="Learn cards:" />
                                </TextBlock>
                                <TextBlock>
                                    <Run Foreground="{StaticResource MaterialDesign.Brush.Primary}" Text="{Binding Path=.}" />
                                    <Run Text="/" />
                                    <Run FontWeight="Bold" Text="{Binding RelativeSource={RelativeSource AncestorType=Grid}, Path=DataContext.MaxLearnCardsCount}" />
                                </TextBlock>
                            </StackPanel>

                        </Border>
                    </DataTemplate>
                </controls:CustomNumericControl.ContentTemplate>
            </controls:CustomNumericControl>

            <controls:CustomNumericControl
                Margin="0,0,0,0"
                DefaultValue="{Binding DefaultReviewCardsCount}"
                Frequency="1"
                MaxValue="{Binding MaxReviewCardsCount}"
                MinValue="0"
                MouseOverOverlay="{StaticResource MaterialDesign.Brush.Primary.Foreground}"
                Value="{Binding ReviewCardsCount, Mode=TwoWay}">
                <controls:CustomNumericControl.ContentTemplate>
                    <DataTemplate>
                        <Border
                            Padding="3"
                            BorderThickness="1"
                            CornerRadius="3">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Width="85">
                                    <Run Text="Review cards:" />
                                </TextBlock>
                                <TextBlock>
                                    <Run Foreground="{StaticResource MaterialDesign.Brush.Primary}" Text="{Binding Path=.}" />
                                    <Run Text="/" />
                                    <Run FontWeight="Bold" Text="{Binding RelativeSource={RelativeSource AncestorType=Grid}, Path=DataContext.MaxReviewCardsCount}" />
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </controls:CustomNumericControl.ContentTemplate>
            </controls:CustomNumericControl>
        </StackPanel>

        <StackPanel
            Grid.Row="1"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Width="60"
                Padding="0"
                Command="{Binding StartTrainingCommand}"
                Content="Start" />

            <Button
                Width="60"
                Margin="3,0,0,0"
                Padding="0"
                Command="{Binding CancelTrainingCommand}"
                Content="Cancel" />
        </StackPanel>

    </Grid>






</UserControl>
