<UserControl
    x:Class="FancyCards.Views.CardListView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:FancyCards.Behaviors"
    xmlns:controls="clr-namespace:FancyCards.Controls"
    xmlns:converters="clr-namespace:FancyCards.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:FancyCards.Helpers"
    xmlns:interation="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:FancyCards.Views"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:FancyCards.ViewModels"
    x:Name="root"
    d:DataContext="{d:DesignInstance vm:CardListViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Background="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Background}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />
        <converters:IsNullTovisibilityConverter x:Key="IsNullTovisibilityConverter" />


        <DataTemplate x:Key="ReviewingTemplate">
            <StackPanel Orientation="Vertical">
                <Grid>
                    <materialDesign:PackIcon
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Foreground="{DynamicResource StateIconBrush}"
                        Kind="RefreshCircle" />

                </Grid>

                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontFamily="Bahnschrift"
                    FontSize="10"
                    Text="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext.ReviewingCount}" />
            </StackPanel>

        </DataTemplate>
        <DataTemplate x:Key="LearningTemplate">
            <StackPanel Orientation="Vertical">
                <materialDesign:PackIcon
                    HorizontalAlignment="Center"
                    Foreground="{DynamicResource StateIconBrush}"
                    Kind="School" />
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontFamily="Bahnschrift"
                    FontSize="10"
                    Text="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext.LearningCount}" />
            </StackPanel>
        </DataTemplate>
        <DataTemplate x:Key="ArchivedTemplate">
            <StackPanel Orientation="Vertical">
                <materialDesign:PackIcon
                    HorizontalAlignment="Center"
                    Foreground="{DynamicResource StateIconBrush}"
                    Kind="Archive" />
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontFamily="Bahnschrift"
                    FontSize="10"
                    Text="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext.ArchivedCount}" />
            </StackPanel>
        </DataTemplate>
        <DataTemplate x:Key="ScheduledTemplate">
            <StackPanel Orientation="Vertical">
                <materialDesign:PackIcon
                    HorizontalAlignment="Center"
                    Foreground="{DynamicResource StateIconBrush}"
                    Kind="Clock" />
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontFamily="Bahnschrift"
                    FontSize="10"
                    Text="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext.ScheduledCount}" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="TotalTemplate">
            <StackPanel Orientation="Vertical">
                <materialDesign:PackIcon
                    HorizontalAlignment="Center"
                    Foreground="{DynamicResource StateIconBrush}"
                    Kind="Cards" />
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontFamily="Bahnschrift"
                    FontSize="10"
                    Text="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext.TotalCount}" />
            </StackPanel>
        </DataTemplate>

        <helpers:CardStateTemplateSelector
            x:Key="CardStateTemplateSelector"
            ArchivedTemplate="{StaticResource ArchivedTemplate}"
            LearningTemplate="{StaticResource LearningTemplate}"
            ReviewingTemplate="{StaticResource ReviewingTemplate}"
            ScheduledTemplate="{StaticResource ScheduledTemplate}"
            TotalTemplate="{StaticResource TotalTemplate}" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <!--  SELECTED DECK  -->
        <Button
            Grid.Row="0"
            Width="auto"
            VerticalAlignment="Center"
            Command="{Binding OpenDeckListModalCommand}"
            Style="{StaticResource CustomButtonStyleNoBg}">
            <Button.Content>
                <TextBlock Style="{StaticResource MaterialDesignHeadline6TextBlock}" Text="{Binding DeckName}" />
            </Button.Content>
        </Button>


        <!--  MENU  -->
        <StackPanel
            Grid.Row="0"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Orientation="Horizontal">
            <Button
                Padding="10,0"
                ClickMode="Press"
                Style="{StaticResource CustomButtonStyleNoBg}">
                <interation:Interaction.Behaviors>
                    <behaviors:OpenContextMenuBehavior Button="Left" Command="{Binding OpenMenuCommand}" />
                </interation:Interaction.Behaviors>
                <materialDesign:PackIcon
                    Width="20"
                    Height="20"
                    Kind="Menu" />
            </Button>
        </StackPanel>


        <!--  CARDS  -->
        <Border
            Grid.Row="1"
            Margin="0,5"
            BorderBrush="{DynamicResource PrimaryForeground}"
            BorderThickness="1"
            CornerRadius="3"
            DockPanel.Dock="Top">
            <ListView materialDesign:RippleAssist.IsDisabled="True" ItemsSource="{Binding Cards}">
                <ListView.ItemContainerStyle>
                    <Style BasedOn="{StaticResource MaterialDesignListBoxItem}" TargetType="ListViewItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="VerticalContentAlignment" Value="Stretch" />
                        <!--<Setter Property="Background" Value="White" />-->
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>

                    <DataTemplate>
                        <Border Background="Transparent">
                            <interation:Interaction.Behaviors>
                                <behaviors:OpenContextMenuBehavior Command="{Binding RelativeSource={RelativeSource AncestorType=ListView}, Path=DataContext.OpenCardContextCommand}" Parameter="{Binding}" />
                            </interation:Interaction.Behaviors>
                            <Grid Margin="10">

                                <TextBlock Foreground="{DynamicResource PrimaryForeground}" Text="{Binding FrontText}" />
                            </Grid>
                        </Border>

                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>


        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <!--  BUTTONS  -->
            <StackPanel
                x:Name="ButtonsPanel"
                Grid.Row="2"
                Grid.Column="0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                SnapsToDevicePixels="True"
                UseLayoutRounding="True">

                <Button
                    Width="70"
                    Margin="0,0,5,0"
                    Padding="0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch"
                    BorderBrush="{DynamicResource PrimaryForeground}"
                    ClickMode="Press"
                    Command="{Binding OpenStartTrainingModalCommand}"
                    Foreground="{DynamicResource ThemeForeground}"
                    SnapsToDevicePixels="True">
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Stretch"
                        Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="17"
                            Height="17"
                            Margin="1,0,1,0"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource StateIconBrush}"
                            Kind="Dumbbell" />
                        <TextBlock
                            Grid.Column="1"
                            Margin="2,0"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Text="Start" />
                    </StackPanel>

                </Button>

                <Button
                    Width="70"
                    Padding="0,0"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch"
                    BorderBrush="{DynamicResource PrimaryForeground}"
                    ClickMode="Press"
                    Command="{Binding OpenCardDetailModalCommand}"
                    Foreground="{DynamicResource ThemeForeground}"
                    SnapsToDevicePixels="True">
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Stretch"
                        Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="24"
                            Height="24"
                            Margin="-3,0"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource StateIconBrush}"
                            Kind="plus" />
                        <TextBlock
                            Grid.Column="1"
                            Margin="2,0"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Text="Create" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <!--  STATES  -->
            <Border
                x:Name="StatesBorder"
                Grid.Row="2"
                Grid.Column="1"
                Padding="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <ListView
                    Margin="2"
                    Cursor="Hand"
                    ItemTemplateSelector="{StaticResource CardStateTemplateSelector}"
                    ItemsSource="{Binding States}"
                    SelectedValue="{Binding SelectedState, Mode=TwoWay}">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Margin" Value="0.5,0" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Focusable" Value="True" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border
                                            x:Name="Bd"
                                            Width="32"
                                            Height="32"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            BorderThickness="1"
                                            CornerRadius="2"
                                            SnapsToDevicePixels="True"
                                            ToolTip="{Binding}"
                                            UseLayoutRounding="True">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>

                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource InactiveForeground}" />
                                            </Trigger>

                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource PrimaryForeground}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>


                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                </ListView>
            </Border>

            <!--  SEARCH  -->
            <controls:WrapperControl
                Grid.Row="2"
                Grid.Column="2"
                Width="{Binding ElementName=ButtonsPanel, Path=ActualWidth}"
                Margin="5,0,0,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                WrapperBackground="{Binding ElementName=root, Path=Background}"
                WrapperForeground="{DynamicResource SearchIconBrush}">
                <controls:WrapperControl.Prefix>
                    <materialDesign:PackIcon Kind="Search" />
                </controls:WrapperControl.Prefix>
                <TextBox
                    Padding="5,7"
                    materialDesign:HintAssist.Hint=""
                    materialDesign:HintAssist.HintPaddingBrush="Transparent"
                    materialDesign:TextFieldAssist.HasClearButton="True"
                    BorderBrush="{DynamicResource PrimaryForeground}"
                    Text="{Binding FrontTextFilter, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                    TextWrapping="Wrap" />
            </controls:WrapperControl>
        </Grid>

    </Grid>
</UserControl>
