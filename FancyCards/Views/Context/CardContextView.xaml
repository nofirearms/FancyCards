<UserControl
    x:Class="FancyCards.Views.CardContextView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:FancyCards.Views"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <StackPanel Orientation="Vertical">
        <StackPanel Orientation="Horizontal">
            <Button
                Margin="0,0,3,0"
                Command="{Binding EditCommand}"
                Content="{materialDesign:PackIcon Kind=Edit}" />
            <Button Command="{Binding RemoveCommand}" Content="{materialDesign:PackIcon Kind=Delete}" />
        </StackPanel>

    </StackPanel>
</UserControl>
