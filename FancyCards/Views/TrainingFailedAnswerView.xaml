<UserControl
    x:Class="FancyCards.Views.TrainingFailedAnswerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:FancyCards.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:FancyCards.ViewModels"
    d:DataContext="{d:DesignInstance vm:TrainingFailedAnswerViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <Border>
            <Grid MinWidth="300">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>
                <TextBlock
                    Grid.Row="0"
                    Margin="0,0,0,5"
                    HorizontalAlignment="Center"
                    FontSize="18"
                    Text="Incorrect"
                    TextWrapping="Wrap" />
                <StackPanel Grid.Row="1" Orientation="Vertical">

                    <TextBlock
                        Margin="0,0,0,5"
                        HorizontalAlignment="Left"
                        FontWeight="Bold"
                        Text="Correct:" />

                    <TextBlock
                        Margin="0,0,0,5"
                        HorizontalAlignment="Left"
                        Text="{Binding FrontText}"
                        TextWrapping="Wrap" />

                    <TextBlock
                        Margin="0,0,0,5"
                        HorizontalAlignment="Left"
                        FontWeight="Bold"
                        Text="Answer:" />

                    <TextBlock
                        Margin="0,0,0,5"
                        HorizontalAlignment="Left"
                        Text="{Binding Answer}"
                        TextWrapping="Wrap" />
                </StackPanel>

                <Button
                    Grid.Row="2"
                    Width="60"
                    Height="30"
                    Margin="5,0,0,0"
                    Padding="0"
                    Command="{Binding OkCommand}"
                    Content="Ok" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
