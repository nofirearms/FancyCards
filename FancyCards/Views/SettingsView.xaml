<UserControl
    x:Class="FancyCards.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:FancyCards.Controls"
    xmlns:converters="clr-namespace:FancyCards.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:FancyCards.Views"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:FancyCards.ViewModels"
    x:Name="root"
    Width="300"
    d:Background="White"
    d:DataContext="{d:DesignInstance vm:SettingsViewModel}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>
    <StackPanel Orientation="Vertical">

        <Grid>
            <controls:HintControl Hint="Capture Device" HintBackground="{StaticResource MaterialDesign.Brush.Secondary.Light}">
                <ComboBox
                    Padding="10"
                    materialDesign:HintAssist.Hint=""
                    materialDesign:HintAssist.HintPaddingBrush="Transparent"
                    DisplayMemberPath="Name"
                    ItemsSource="{Binding CaptureDevices}"
                    SelectedValue="{Binding CaptureDeviceId, Mode=TwoWay}"
                    SelectedValuePath="ID"
                    Style="{StaticResource MaterialDesignOutlinedComboBox}" />

            </controls:HintControl>
            <TextBlock
                Margin="12,11,20,11"
                Text="{Binding CaptureDeviceName}"
                Visibility="{Binding DevicesLoaded, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Reversed}" />
        </Grid>


        <Grid Margin="0,5,0,0">
            <controls:HintControl Hint="Theme" HintBackground="{StaticResource MaterialDesign.Brush.Secondary.Light}">
                <ComboBox
                    Padding="10"
                    materialDesign:HintAssist.Hint=""
                    materialDesign:HintAssist.HintPaddingBrush="Transparent"
                    ItemsSource="{Binding Themes}"
                    SelectedItem="{Binding Theme, Mode=TwoWay}"
                    Style="{StaticResource MaterialDesignOutlinedComboBox}" />

            </controls:HintControl>
        </Grid>


        <TextBlock>
            <Run Foreground="{DynamicResource MainForeground}" Text="Progress:" />
            <Run Foreground="Green" Text="{Binding Info}" />
        </TextBlock>

        <Button
            Margin="0,5,0,0"
            Command="{Binding RunScriptCommand}"
            Content="Run Script" />

        <Button
            Margin="0,5,0,0"
            Command="{Binding ExportOldDataCommand}"
            Content="Export old data" />

        <StackPanel
            Margin="0,5,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Grid.Row="2"
                Width="60"
                Height="30"
                Margin="5,0,0,0"
                Padding="0"
                Command="{Binding SaveCommand}"
                Content="Save" />
            <Button
                Grid.Row="2"
                Width="60"
                Height="30"
                Margin="5,0,0,0"
                Padding="0"
                Command="{Binding CancelCommand}"
                Content="Cancel" />
        </StackPanel>


    </StackPanel>
</UserControl>
