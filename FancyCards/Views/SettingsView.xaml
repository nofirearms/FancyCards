<UserControl
    x:Class="FancyCards.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:FancyCards.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:FancyCards.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:FancyCards.ViewModels"
    Width="300"
    d:Background="White"
    d:DataContext="{d:DesignInstance vm:SettingsViewModel}"
    mc:Ignorable="d">
    <StackPanel Orientation="Vertical">

        <TextBlock>
            <Run Text="Progress:" />
            <Run Foreground="Green" Text="{Binding Info}" />
        </TextBlock>

        <Button
            Margin="0,5,0,0"
            Command="{Binding RunScriptCommand}"
            Content="Run Script" />

        <Button
            Margin="0,5,0,0"
            Command="{Binding ExportOldDataCommand}"
            Content="Export old data" />

        <StackPanel
            Margin="0,5,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Grid.Row="2"
                Width="60"
                Height="30"
                Margin="5,0,0,0"
                Padding="0"
                Command="{Binding SaveCommand}"
                Content="Save" />
            <Button
                Grid.Row="2"
                Width="60"
                Height="30"
                Margin="5,0,0,0"
                Padding="0"
                Command="{Binding CancelCommand}"
                Content="Cancel" />
        </StackPanel>


    </StackPanel>
</UserControl>
