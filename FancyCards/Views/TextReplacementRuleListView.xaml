<UserControl
    x:Class="FancyCards.Views.TextReplacementRuleListView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:FancyCards.Behaviors"
    xmlns:controls="clr-namespace:FancyCards.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:interaction="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:FancyCards.Views"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:FancyCards.ViewModels"
    x:Name="root"
    Width="300"
    Height="400"
    d:DataContext="{d:DesignInstance vm:TextReplacementRuleListViewModel}"
    Background="{DynamicResource MaterialDesign.Brush.Secondary.Light}"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <controls:HintControl
            Grid.Row="0"
            Margin="0"
            HintBackground="{Binding ElementName=root, Path=Background}">
            <controls:HintControl.Hint>
                <materialDesign:PackIcon Kind="Search" />
            </controls:HintControl.Hint>
            <TextBox
                materialDesign:HintAssist.Hint=""
                materialDesign:HintAssist.HintPaddingBrush="Transparent"
                materialDesign:TextFieldAssist.HasClearButton="True"
                Text="{Binding TextFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </controls:HintControl>

        <Border
            Grid.Row="1"
            Margin="0,5"
            Style="{StaticResource CustomBorderSimpleStyle}">
            <ListView
                materialDesign:RippleAssist.IsDisabled="True"
                AlternationCount="2"
                ItemsSource="{Binding Rules}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="Transparent">
                            <interaction:Interaction.Behaviors>
                                <behaviors:OpenContextMenuBehavior Command="{Binding RelativeSource={RelativeSource AncestorType=ListView}, Path=DataContext.OpenContextCommand}" Parameter="{Binding}" />
                            </interaction:Interaction.Behaviors>
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="30" />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <TextBlock FontSize="16" Text="{Binding Original}" />
                                <materialDesign:PackIcon Grid.Column="1" Kind="ArrowRightBold" />
                                <TextBlock
                                    Grid.Column="2"
                                    FontSize="16"
                                    Text="{Binding Replacement}" />

                            </Grid>
                        </Border>

                    </DataTemplate>
                </ListView.ItemTemplate>
                <ListView.ItemContainerStyle>
                    <Style BasedOn="{StaticResource MaterialDesignListBoxItem}" TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="VerticalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Style.Triggers>
                            <Trigger Property="ItemsControl.AlternationIndex" Value="0">
                                <Setter Property="Background" Value="Transparent" />
                            </Trigger>
                            <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Opacity="0.2" Color="White" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>
        </Border>

        <StackPanel
            Grid.Row="2"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button Command="{Binding CloseModalCommand}" Content="Close" />
        </StackPanel>
        <StackPanel
            Grid.Row="2"
            HorizontalAlignment="Left"
            Orientation="Horizontal">
            <Button
                Width="35"
                Padding="0"
                Command="{Binding AddCommand}">
                <materialDesign:PackIcon Kind="Add" />
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
