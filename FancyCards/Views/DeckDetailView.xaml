<UserControl
    x:Class="FancyCards.Views.DeckDetailView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:FancyCards.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:FancyCards.Views"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:vm="clr-namespace:FancyCards.ViewModels"
    Width="250"
    Height="auto"
    d:DataContext="{d:DesignInstance vm:DeckDetailViewModel}"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <StackPanel VerticalAlignment="Top" Orientation="Vertical">
            <controls:HintControl
                Margin="0,0,0,5"
                HintBackground="{DynamicResource MaterialDesign.Brush.Secondary.Light}"
                HintText="Name">
                <TextBox
                    materialDesign:HintAssist.Hint=""
                    materialDesign:HintAssist.HintPaddingBrush="Transparent"
                    Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
            </controls:HintControl>

            <controls:HintControl
                Margin="0,0,0,5"
                HintBackground="{DynamicResource MaterialDesign.Brush.Secondary.Light}"
                HintText="Description">
                <TextBox
                    materialDesign:HintAssist.Hint=""
                    materialDesign:HintAssist.HintPaddingBrush="Transparent"
                    AcceptsReturn="True"
                    Text="{Binding Description, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                    TextWrapping="Wrap" />
            </controls:HintControl>

            <controls:HintControl
                Margin="0,0,0,5"
                HintBackground="{DynamicResource MaterialDesign.Brush.Secondary.Light}"
                HintText="Profile">
                <ComboBox
                    Padding="10"
                    DisplayMemberPath="Name"
                    ItemsSource="{Binding Profiles}"
                    SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                    Style="{StaticResource MaterialDesignOutlinedComboBox}" />
            </controls:HintControl>

            <controls:CustomNumericControl
                Margin="0,0,0,5"
                DefaultValue="10"
                Frequency="1"
                MaxValue="100"
                MinValue="0"
                Value="{Binding TrainingLearnCards, Mode=TwoWay}">
                <controls:CustomNumericControl.ContentTemplate>
                    <DataTemplate>
                        <Border BorderThickness="1" CornerRadius="3">
                            <TextBlock>
                                <Run Text="Training learn cards:" />
                                <Run Text="{Binding Path=.}" />
                            </TextBlock>
                        </Border>
                    </DataTemplate>
                </controls:CustomNumericControl.ContentTemplate>
            </controls:CustomNumericControl>

            <controls:CustomNumericControl
                Margin="0,0,0,5"
                DefaultValue="10"
                Frequency="1"
                MaxValue="100"
                MinValue="0"
                Value="{Binding TrainingReviewCards, Mode=TwoWay}">
                <controls:CustomNumericControl.ContentTemplate>
                    <DataTemplate>
                        <Border BorderThickness="1" CornerRadius="3">
                            <TextBlock>
                                <Run Text="Training review cards:" />
                                <Run Text="{Binding Path=.}" />
                            </TextBlock>
                        </Border>
                    </DataTemplate>
                </controls:CustomNumericControl.ContentTemplate>
            </controls:CustomNumericControl>

            <controls:CustomNumericControl
                Margin="0,0,0,5"
                DefaultValue="2"
                Frequency="1"
                MaxValue="100"
                MinValue="1"
                Value="{Binding CorrectAnswersToFinishLearning, Mode=TwoWay}">
                <controls:CustomNumericControl.ContentTemplate>
                    <DataTemplate>
                        <Border BorderThickness="1" CornerRadius="3">
                            <TextBlock>
                                <Run Text="Correct answers to finish learning:" />
                                <Run Text="{Binding Path=.}" />
                            </TextBlock>
                        </Border>
                    </DataTemplate>
                </controls:CustomNumericControl.ContentTemplate>
            </controls:CustomNumericControl>

            <controls:CustomNumericControl
                Margin="0,0,0,5"
                DefaultValue="30"
                Frequency="1"
                MaxValue="{x:Static sys:Int32.MaxValue}"
                MinValue="1"
                Value="{Binding MaxIntervalDays, Mode=TwoWay}">
                <controls:CustomNumericControl.ContentTemplate>
                    <DataTemplate>
                        <Border BorderThickness="1" CornerRadius="3">
                            <TextBlock>
                                <Run Text="Archive after (days):" />
                                <Run Text="{Binding Path=.}" />
                            </TextBlock>
                        </Border>
                    </DataTemplate>
                </controls:CustomNumericControl.ContentTemplate>
            </controls:CustomNumericControl>



        </StackPanel>

        <StackPanel
            Grid.Row="1"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Width="60"
                Padding="0"
                Command="{Binding SaveCommand}"
                Content="Save" />
            <Button
                Width="60"
                Margin="3,0,0,0"
                Padding="0"
                Command="{Binding CloseModalCommand}"
                Content="Cancel" />
        </StackPanel>
    </Grid>

</UserControl>
