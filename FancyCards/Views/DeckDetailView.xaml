<UserControl
    x:Class="FancyCards.Views.DeckDetailView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:FancyCards.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:FancyCards.Views"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:FancyCards.ViewModels"
    Width="auto"
    Height="auto"
    d:DataContext="{d:DesignInstance vm:DeckDetailViewModel}"
    mc:Ignorable="d">
    <Grid>
        <StackPanel
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Orientation="Vertical">
            <controls:HintControl
                Margin="0,0,0,5"
                HintBackground="{DynamicResource MaterialDesign.Brush.Secondary.Light}"
                HintText="Name">
                <TextBox
                    materialDesign:HintAssist.Hint=""
                    materialDesign:HintAssist.HintPaddingBrush="Transparent"
                    Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
            </controls:HintControl>

            <controls:HintControl
                Margin="0,0,0,5"
                HintBackground="{DynamicResource MaterialDesign.Brush.Secondary.Light}"
                HintText="Name">
                <TextBox
                    materialDesign:HintAssist.Hint=""
                    materialDesign:HintAssist.HintPaddingBrush="Transparent"
                    AcceptsReturn="True"
                    Text="{Binding Description, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                    TextWrapping="Wrap" />
            </controls:HintControl>

        </StackPanel>

        <StackPanel Orientation="Horizontal">
            <Button Command="{Binding SaveCommand}" Content="Save" />
            <Button Command="{Binding CloseModalCommand}" Content="Cancel" />
        </StackPanel>
    </Grid>

</UserControl>
