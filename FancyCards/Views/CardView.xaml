<UserControl
    x:Class="FancyCards.Views.CardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:FancyCards.Views"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:FancyCards.ViewModels"
    d:DataContext="{d:DesignInstance vm:CardViewViewModel}"
    d:DesignHeight="700"
    d:DesignWidth="400"
    mc:Ignorable="d">
    <StackPanel Orientation="Vertical">
        <TextBox
            materialDesign:HintAssist.Hint="Front"
            Style="{StaticResource MaterialDesignOutlinedTextBox}"
            Text="{Binding FrontText}" />
        <Button Command="{Binding AcceptCommand}" Content="{materialDesign:PackIcon Kind=ContentSave}" />
    </StackPanel>
</UserControl>
