<UserControl
    x:Class="FancyCards.Views.TrainingResultView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:FancyCards.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:FancyCards.ViewModels"
    d:DataContext="{d:DesignInstance vm:TrainingResultViewModel}"
    Height="150"
    Width="150"
    mc:Ignorable="d">
    <StackPanel>
        <TextBlock FontSize="22" Text="RESULT!" />
        <Button
            Grid.Row="2"
            Width="60"
            Height="30"
            Margin="5,0,0,0"
            Padding="0"
            Command="{Binding OkCommand}"
            Content="Ok" />
    </StackPanel>
</UserControl>
