<UserControl
    x:Class="FancyCards.Views.CardDetailView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:FancyCards.Behaviors"
    xmlns:controls="clr-namespace:FancyCards.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:interactions="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:FancyCards.Views"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:FancyCards.ViewModels"
    d:Background="GreenYellow"
    d:DataContext="{d:DesignInstance vm:CardDetailViewModel}"
    mc:Ignorable="d">

    <Grid Width="400" Height="auto">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="1" Orientation="Vertical">
            <Grid Margin="0,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>


                <controls:WrapperControl
                    x:Name="Prefix"
                    Grid.Column="0"
                    Prefix="Prefix"
                    Suffix="{Binding PrefixText.Length, UpdateSourceTrigger=PropertyChanged}"
                    WrapperBackground="{Binding Background}"
                    WrapperFontSize="12"
                    WrapperForeground="{DynamicResource StateIconBrush}">
                    <TextBox
                        materialDesign:HintAssist.Hint=""
                        materialDesign:HintAssist.HintPaddingBrush="Transparent"
                        AcceptsReturn="True"
                        Text="{Binding PrefixText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                        TextWrapping="Wrap" />
                </controls:WrapperControl>


                <controls:WrapperControl
                    x:Name="Suffix"
                    Grid.Column="1"
                    Prefix="Suffix"
                    Suffix="{Binding SuffixText.Length, UpdateSourceTrigger=PropertyChanged}"
                    WrapperBackground="{Binding Background}"
                    WrapperFontSize="12"
                    WrapperForeground="{DynamicResource StateIconBrush}">
                    <TextBox
                        materialDesign:HintAssist.Hint=""
                        materialDesign:HintAssist.HintPaddingBrush="Transparent"
                        AcceptsReturn="True"
                        Text="{Binding SuffixText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                        TextWrapping="Wrap" />
                </controls:WrapperControl>
            </Grid>


            <controls:WrapperControl
                Margin="0,0,0,5"
                Prefix="Front"
                Suffix="{Binding FrontText.Length, UpdateSourceTrigger=PropertyChanged}"
                WrapperBackground="{Binding Background}"
                WrapperFontSize="12"
                WrapperForeground="{DynamicResource StateIconBrush}">
                <TextBox
                    materialDesign:HintAssist.Hint=""
                    materialDesign:HintAssist.HintPaddingBrush="Transparent"
                    AcceptsReturn="True"
                    Text="{Binding FrontText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                    TextAlignment="Left"
                    TextWrapping="Wrap" />
            </controls:WrapperControl>

            <controls:WrapperControl
                Margin="0,0,0,5"
                Prefix="Back"
                Suffix="{Binding BackText.Length, UpdateSourceTrigger=PropertyChanged}"
                WrapperBackground="{Binding Background}"
                WrapperFontSize="12"
                WrapperForeground="{DynamicResource StateIconBrush}">
                <TextBox
                    materialDesign:HintAssist.Hint=""
                    materialDesign:HintAssist.HintPaddingBrush="Transparent"
                    AcceptsReturn="True"
                    Text="{Binding BackText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                    TextAlignment="Left"
                    TextWrapping="Wrap" />
            </controls:WrapperControl>


            <controls:WrapperControl
                Margin="0,0,0,5"
                Prefix="Comment"
                Suffix="{Binding CommentText.Length, UpdateSourceTrigger=PropertyChanged}"
                WrapperBackground="{Binding Background}"
                WrapperFontSize="12"
                WrapperForeground="{DynamicResource StateIconBrush}">
                <TextBox
                    materialDesign:HintAssist.Hint=""
                    materialDesign:HintAssist.HintPaddingBrush="Transparent"
                    AcceptsReturn="True"
                    Text="{Binding CommentText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                    TextAlignment="Left"
                    TextWrapping="Wrap" />
            </controls:WrapperControl>

            <controls:WrapperControl
                Margin="0,0,0,5"
                Prefix="Message"
                Suffix="{Binding MessageText.Length, UpdateSourceTrigger=PropertyChanged}"
                WrapperBackground="{Binding Background}"
                WrapperFontSize="12"
                WrapperForeground="{DynamicResource StateIconBrush}">
                <TextBox
                    materialDesign:HintAssist.Hint=""
                    materialDesign:HintAssist.HintPaddingBrush="Transparent"
                    AcceptsReturn="True"
                    Text="{Binding MessageText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                    TextAlignment="Left"
                    TextWrapping="Wrap" />
            </controls:WrapperControl>


            <Grid Margin="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <StackPanel
                    Grid.Column="0"
                    Margin="0,0,1,0"
                    Orientation="Vertical">
                    <controls:WrapperControl
                        Grid.Column="0"
                        Margin="0,0,1,0"
                        Prefix="State"
                        WrapperBackground="{Binding Background}"
                        WrapperFontSize="12"
                        WrapperForeground="{DynamicResource StateIconBrush}">
                        <ComboBox
                            Padding="10"
                            materialDesign:HintAssist.Hint=""
                            materialDesign:HintAssist.HintPaddingBrush="Transparent"
                            ItemsSource="{Binding States}"
                            SelectedValue="{Binding SelectedState, Mode=TwoWay}"
                            Style="{StaticResource MaterialDesignOutlinedComboBox}" />
                    </controls:WrapperControl>
                </StackPanel>

                <StackPanel
                    Grid.Column="1"
                    Margin="1,0,0,0"
                    Orientation="Vertical">

                    <controls:WrapperControl
                        Grid.Column="0"
                        Margin="0,0,1,0"
                        Prefix="Review date"
                        WrapperBackground="{Binding Background}"
                        WrapperFontSize="12"
                        WrapperForeground="{DynamicResource StateIconBrush}">
                        <DatePicker
                            Padding="10"
                            materialDesign:HintAssist.Hint=""
                            materialDesign:HintAssist.HintPaddingBrush="Transparent"
                            SelectedDate="{Binding NextReviewDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}" />
                    </controls:WrapperControl>


                    <controls:WrapperControl
                        Grid.Column="0"
                        Margin="0,5,0,0"
                        Prefix="Created at"
                        WrapperBackground="{Binding Background}"
                        WrapperFontSize="12"
                        WrapperForeground="{DynamicResource StateIconBrush}">
                        <DatePicker
                            Padding="10"
                            materialDesign:HintAssist.Hint=""
                            materialDesign:HintAssist.HintPaddingBrush="Transparent"
                            IsHitTestVisible="False"
                            SelectedDate="{Binding DateCreated}"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}" />
                        <interactions:Interaction.Triggers>
                            <interactions:DataTrigger Binding="{Binding CardAction}" Value="Create">
                                <interactions:ChangePropertyAction PropertyName="Visibility" Value="Collapsed" />
                            </interactions:DataTrigger>
                            <interactions:DataTrigger Binding="{Binding CardAction}" Value="Update">
                                <interactions:ChangePropertyAction PropertyName="Visibility" Value="Visible" />
                            </interactions:DataTrigger>
                        </interactions:Interaction.Triggers>
                    </controls:WrapperControl>
                </StackPanel>
            </Grid>

            <Grid>
                <local:AudioSamplerView DataContext="{Binding AudioSamplerViewModel}" />
                <StackPanel
                    Margin="5,50"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top">
                    <Button
                        Width="auto"
                        Height="15"
                        Command="{Binding ChooseCaptureDeviceCommand}"
                        Content="{Binding CaptureDeviceName}"
                        FontSize="12"
                        FontWeight="Normal"
                        Style="{StaticResource CustomButtonStyleNoBg}" />
                </StackPanel>
            </Grid>

        </StackPanel>
        <StackPanel
            Grid.Row="2"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Margin="5,0"
                Command="{Binding SaveCardCommand}"
                Content="{materialDesign:PackIcon Kind=ContentSave}" />
            <Button Command="{Binding CancelCommand}" Content="{materialDesign:PackIcon Kind=Close}" />
        </StackPanel>
    </Grid>

</UserControl>
