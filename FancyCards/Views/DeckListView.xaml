<UserControl
    x:Class="FancyCards.Views.DeckListView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:FancyCards.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:FancyCards.Views"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:FancyCards.ViewModels"
    x:Name="root"
    Width="300"
    Height="400"
    d:DataContext="{d:DesignInstance vm:DeckListViewModel}"
    Background="{DynamicResource MaterialDesign.Brush.Secondary.Light}"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <controls:HintControl
            Grid.Row="0"
            Margin="0,0,0,5"
            HintBackground="{Binding ElementName=root, Path=Background}">
            <controls:HintControl.Hint>
                <materialDesign:PackIcon Kind="Search" />
            </controls:HintControl.Hint>
            <TextBox
                materialDesign:HintAssist.Hint=""
                materialDesign:HintAssist.HintPaddingBrush="Transparent"
                materialDesign:TextFieldAssist.HasClearButton="True"
                Text="" />
        </controls:HintControl>


        <Border Grid.Row="1" Style="{StaticResource CustomBorderSimpleStyle}">
            <ListView
                materialDesign:RippleAssist.IsDisabled="True"
                ItemsSource="{Binding Decks}"
                SelectedItem="{Binding SelectedDeck, Mode=TwoWay}">
                <ListView.ItemContainerStyle>
                    <Style BasedOn="{StaticResource MaterialDesignListBoxItem}" TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="auto" MinWidth="25" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Name}" />
                            <materialDesign:PackIcon
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                Kind="CardsPlaying" />
                            <TextBlock
                                Grid.Column="2"
                                HorizontalAlignment="Right"
                                Text="{Binding CardsCount}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <Grid Grid.Row="2" Margin="0,5,0,0">
            <StackPanel Orientation="Horizontal">
                <Button
                    Width="35"
                    Margin="3,0,0,0"
                    Padding="0"
                    Command="{Binding CreateDeckCommand}">
                    <materialDesign:PackIcon Kind="Add" />
                </Button>
                <Button
                    Width="35"
                    Margin="3,0,0,0"
                    Padding="0"
                    Command="{Binding CreateDeckCommand}"
                    CommandParameter="{Binding SelectedDeck.Deck}">
                    <materialDesign:PackIcon Kind="Edit" />
                </Button>
            </StackPanel>
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button
                    Width="60"
                    Padding="0"
                    Command="{Binding SelectCommand}"
                    Content="Select" />
                <Button
                    Width="60"
                    Margin="3,0,0,0"
                    Padding="0"
                    Command="{Binding CloseModalCommand}"
                    Content="Cancel" />
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>
