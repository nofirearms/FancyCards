<UserControl
    x:Class="FancyCards.Views.TrainingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:FancyCards.Behaviors"
    xmlns:controls="clr-namespace:FancyCards.Controls"
    xmlns:converters="clr-namespace:FancyCards.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:FancyCards.Helpers"
    xmlns:interaction="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:FancyCards.Views"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:FancyCards.ViewModels"
    Width="450"
    Height="auto"
    d:Background="{DynamicResource MaterialDesign.Brush.Secondary.Light}"
    d:DataContext="{d:DesignInstance vm:TrainingViewModel}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:DateToDaysPassedStringConverter x:Key="DateToDaysPassedStringConverter" />
        <converters:DateTimeToVisibilityConverter x:Key="DateTimeToVisibilityConverter" />

        <DataTemplate x:Key="EasyTemplate">
            <TextBlock Text="E" />
        </DataTemplate>
        <DataTemplate x:Key="NormalTemplate">
            <TextBlock Text="N" />
        </DataTemplate>
        <DataTemplate x:Key="HardTemplate">
            <TextBlock Text="H" />
        </DataTemplate>

        <helpers:DifficultyTemplateSelector
            x:Key="DifficultyTemplateSelector"
            EasyTemplate="{StaticResource EasyTemplate}"
            HardTemplate="{StaticResource HardTemplate}"
            NormalTemplate="{StaticResource NormalTemplate}" />
    </UserControl.Resources>

    <Grid>
        <StackPanel Orientation="Vertical">

            <Grid Margin="5,5">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon
                        Width="30"
                        Height="30"
                        Foreground="{StaticResource MaterialDesign.Brush.Primary}"
                        ToolTip="{Binding CurrentCard.InitialState}">
                        <interaction:Interaction.Triggers>
                            <interaction:DataTrigger Binding="{Binding CurrentCard.InitialState}" Value="Learning">
                                <interaction:ChangePropertyAction PropertyName="Kind" Value="School" />
                            </interaction:DataTrigger>
                            <interaction:DataTrigger Binding="{Binding CurrentCard.InitialState}" Value="Reviewing">
                                <interaction:ChangePropertyAction PropertyName="Kind" Value="Refresh" />
                            </interaction:DataTrigger>
                        </interaction:Interaction.Triggers>
                    </materialDesign:PackIcon>

                    <StackPanel Margin="10,0" Orientation="Vertical">
                        <TextBlock>
                            <Run Text="Correct:" />
                            <Run
                                FontWeight="Bold"
                                Foreground="{StaticResource MaterialDesign.Brush.Primary}"
                                Text="{Binding CurrentCard.Card.Scores.CorrectCount}" />
                            <Run Text=" | " />
                            <Run Text="Attempts:" />
                            <Run
                                FontWeight="Bold"
                                Foreground="{StaticResource MaterialDesign.Brush.Primary}"
                                Text="{Binding CurrentCard.Card.Scores.TotalCount}" />

                        </TextBlock>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock>
                                <Run Text="Last review:" />
                                <Run
                                    FontWeight="Bold"
                                    Foreground="{StaticResource MaterialDesign.Brush.Primary}"
                                    Text="{Binding CurrentCard.Card.LastReviewDate, Converter={StaticResource DateToDaysPassedStringConverter}}" />
                            </TextBlock>
                            <TextBlock Margin="2,0,0,0" Visibility="{Binding CurrentCard.Card.LastReviewDate, Converter={StaticResource DateTimeToVisibilityConverter}}">
                                <Run Text=" | " />
                                <Run Text="{Binding CurrentCard.Card.LastReviewDate, StringFormat='\{0:dd.MM.yyyy}'}" />
                            </TextBlock>
                        </StackPanel>



                    </StackPanel>

                </StackPanel>

                <StackPanel HorizontalAlignment="Right" Orientation="Vertical">
                    <TextBlock HorizontalAlignment="Right">
                        <Run Text="{Binding CurrentCardIndex}" />
                        <Run Text=" | " />
                        <Run FontWeight="Bold" Text="{Binding TotalCards}" />
                    </TextBlock>
                    <TextBlock>
                        <Run Text="{Binding CurrentCard.SessionDuration}" />
                        <Run Text=" | " />
                        <Run FontWeight="Bold" Text="{Binding TrainingTime}" />
                    </TextBlock>
                </StackPanel>



            </Grid>
            <Grid Margin="0,5,0,0">

                <controls:HintControl HintBackground="{DynamicResource MaterialDesign.Brush.Secondary.Light}" HintText="Back">
                    <TextBox
                        materialDesign:HintAssist.Hint=""
                        materialDesign:HintAssist.HintPaddingBrush="Transparent"
                        IsHitTestVisible="False"
                        TextAlignment="Left"
                        TextWrapping="Wrap">
                        <interaction:Interaction.Triggers>
                            <interaction:DataTrigger Binding="{Binding CurrentCard.ShowBack}" Value="true">
                                <interaction:ChangePropertyAction PropertyName="Text" Value="{Binding CurrentCard.Card.BackText}" />
                            </interaction:DataTrigger>
                            <interaction:DataTrigger Binding="{Binding CurrentCard.ShowBack}" Value="false">
                                <interaction:ChangePropertyAction PropertyName="Text" Value="" />
                            </interaction:DataTrigger>
                        </interaction:Interaction.Triggers>
                    </TextBox>
                </controls:HintControl>

                <RadioButton
                    Width="30"
                    Height="18"
                    Margin="10,-8,10,0"
                    Padding="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    GroupName="1"
                    IsChecked="{Binding CurrentCard.ShowBack, Mode=TwoWay}"
                    Style="{StaticResource CustomRadioButtonSolid}">
                    <materialDesign:PackIcon
                        Width="20"
                        Height="20"
                        Kind="Eye" />
                </RadioButton>
            </Grid>



            <Grid Margin="0,10">
                <controls:HintControl HintBackground="{DynamicResource MaterialDesign.Brush.Secondary.Light}" HintText="Front">
                    <TextBox
                        materialDesign:HintAssist.Hint=""
                        materialDesign:HintAssist.HintPaddingBrush="Transparent"
                        IsHitTestVisible="False"
                        TextAlignment="Left"
                        TextWrapping="Wrap">
                        <interaction:Interaction.Triggers>
                            <interaction:DataTrigger Binding="{Binding CurrentCard.Hint}" Value="true">
                                <interaction:ChangePropertyAction PropertyName="Text" Value="{Binding CurrentCard.Card.FrontText}" />
                            </interaction:DataTrigger>
                            <interaction:DataTrigger Binding="{Binding CurrentCard.Hint}" Value="false">
                                <interaction:ChangePropertyAction PropertyName="Text" Value="" />
                            </interaction:DataTrigger>
                        </interaction:Interaction.Triggers>
                    </TextBox>
                </controls:HintControl>

                <RadioButton
                    Width="30"
                    Height="20"
                    Margin="10,-8,10,0"
                    Padding="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    GroupName="2"
                    IsChecked="{Binding CurrentCard.Hint, Mode=TwoWay}"
                    Style="{StaticResource CustomRadioButtonSolid}">
                    <materialDesign:PackIcon
                        Width="20"
                        Height="20"
                        Kind="Eye" />
                </RadioButton>
            </Grid>

            <controls:HintControl
                Margin="0,0,0,10"
                HintBackground="{DynamicResource MaterialDesign.Brush.Secondary.Light}"
                HintText="Comment">
                <TextBox
                    Padding="10"
                    materialDesign:HintAssist.Hint=""
                    materialDesign:HintAssist.HintPaddingBrush="Transparent"
                    IsHitTestVisible="False"
                    Text="{Binding CurrentCard.Card.CommentText}"
                    TextAlignment="Left"
                    TextWrapping="Wrap" />

            </controls:HintControl>

            <controls:HintControl HintBackground="{DynamicResource MaterialDesign.Brush.Secondary.Light}" HintText="Answer">
                <!--<Grid>
                    <TextBox
                        materialDesign:HintAssist.Hint=""
                        materialDesign:HintAssist.HintPaddingBrush="Transparent"
                        Text="{Binding CurrentCard.Answer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TextAlignment="Left"
                        TextWrapping="Wrap">
                        <interaction:Interaction.Behaviors>
                            <behaviors:SetFocusBehavior />
                        </interaction:Interaction.Behaviors>
                    </TextBox>
                </Grid>-->
                <controls:AnswerTextBoxControl
                    Prefix="{Binding CurrentCard.Card.PrefixText}"
                    Suffix="{Binding CurrentCard.Card.SuffixText}"
                    Text="{Binding CurrentCard.Answer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </controls:HintControl>

            <Grid Margin="40,5,0,5" HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Grid.Column="1"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
                    <Button
                        Width="40"
                        Height="40"
                        Margin="0,0,3,0"
                        Padding="0"
                        Command="{Binding AcceptCommand}"
                        Content="{materialDesign:PackIcon Kind=ArrowRightBold}"
                        IsEnabled="{Binding CurrentCard.Answer.Length}" />

                    <ListView
                        Margin="2"
                        Cursor="Hand"
                        ItemTemplateSelector="{StaticResource DifficultyTemplateSelector}"
                        ItemsSource="{Binding Difficulties}"
                        SelectedIndex="0"
                        SelectedValue="{Binding CurrentCard.Difficulty, Mode=TwoWay}">

                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Focusable" Value="True" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border
                                                x:Name="Bd"
                                                Width="30"
                                                Height="30"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                BorderThickness="1"
                                                CornerRadius="2"
                                                ToolTip="{Binding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>

                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource InactiveForeground}" />
                                                </Trigger>

                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Primary.Foreground}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>


                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                    </ListView>

                    <Button
                        Width="40"
                        Height="40"
                        Margin="2,0,0,0"
                        Padding="0"
                        Command="{Binding AudioPlaybackSelectedCommand}"
                        Content="{materialDesign:PackIcon Kind=play}"
                        ToolTip="Play selected" />
                    <Button
                        Width="40"
                        Height="40"
                        Margin="2,0,0,0"
                        Padding="0"
                        Command="{Binding AudioPlaybackFullCommand}"
                        Content="{materialDesign:PackIcon Kind=PlaySpeed}"
                        ToolTip="Play full" />
                    <Button
                        Width="40"
                        Height="40"
                        Margin="2,0,0,0"
                        Padding="0"
                        Command="{Binding AudioPlaybackSlowCommand}"
                        Content="{materialDesign:PackIcon Kind=FractionOneHalf}"
                        ToolTip="Play slow" />
                    <Button
                        Width="40"
                        Height="40"
                        Margin="2,0,0,0"
                        Padding="0"
                        Command="{Binding AudioStopPlaybackCommand}"
                        Content="{materialDesign:PackIcon Kind=Stop}"
                        ToolTip="Stop" />
                    <materialDesign:PackIcon
                        Width="30"
                        Height="30"
                        Margin="5,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Kind="Speakerphone"
                        Opacity="{Binding MaxSampleVolume}" />
                </StackPanel>

                <Button
                    Grid.Column="2"
                    Width="40"
                    Height="40"
                    Padding="0"
                    HorizontalAlignment="Right"
                    Command="{Binding EditCardCommand}"
                    Content="{materialDesign:PackIcon Kind=Edit}" />

            </Grid>


        </StackPanel>

    </Grid>

</UserControl>
